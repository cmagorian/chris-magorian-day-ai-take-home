# Copy to .env and adjust. Loaded via `node --env-file=.env` (Node 20+) or your process
# manager / container env. Tests ignore this — they use an in-memory DB and silent logs.

# HTTP port
PORT=3000

# SQLite file (created on boot if missing). Use :memory: for a throwaway DB.
DB_FILE=data/secret-santa.db

# pino level: trace|debug|info|warn|error|fatal|silent
LOG_LEVEL=info
